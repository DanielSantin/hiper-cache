{
  "manifest_version": 3,
  "name": "Hiper TAG — Vendas, Estoque e Orçamentos",
  "version": "1.10",
  "key": "",
  "description": "Ferramentas internas do Hiper ERP: orçamentos, estoque, margem de lucro e cadastro de clientes — TAG Drywall.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "https://tagdrywall.hiper.com.br/*",
    "https://api.hiper.com.br/*",
    "https://api.sistema.santin.tec.br/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://tagdrywall.hiper.com.br/*"
      ],
      "js": [
        "interceptor.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "unidades_padrao.js",
        "hiper-sync.js",
        "hiper-icones.js",
        "hiper-cache.js",
        "hiper-widgets.js",
        "hiper-orcamento.js",
        "hiper-lucro-widget.js",
        "hiper-db.js",
        "kit.js",
        "hiper-mov-widget.js",
        "hiper-mov-lista.js",
        "resumido-dados.js",
        "resumido-runtime.js",
        "resumido-gerador.js",
        "hiper-ui.js",
        "hiper-cpf-autofill.js",
        "vendor/html2canvas.min.js",
        "vendor/jspdf.umd.min.js"
      ],
      "matches": [
        "https://tagdrywall.hiper.com.br/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Hiper TAG",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}